def predict_svm_distances(model, X_test, y_test, scaler = False): #calculates the signed distances from the decision boundary for each
    X_test = numpy.array(X_test, dtype = 'float')                 #test point, and returns these values
    distances = model.decision_function(X_test) #positive -> active
    return(distances)

