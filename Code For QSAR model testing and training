import matplotlib.pyplot as plt             #plotting using matplot
from sklearn.metrics import roc_curve

def plot_roc_curve(true_y, y_prob):     
    """
    plots the roc curve based of the probabilities
    """

    fpr, tpr, thresholds = roc_curve(true_y, y_prob)     
    plt.plot(fpr, tpr)                                   #plotting false positive rate and true positive rate
    plt.xlabel('False Positive Rate')                    #x-axis false positive and y-axis true positives 
    plt.ylabel('True Positive Rate')

